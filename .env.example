# HTTP API port
PORT=3333

# Obrigatório — protege todos os endpoints /api/*
# Gere com: openssl rand -hex 32
API_TOKEN=

# FlareSolverr — única forma de coleta (sem Chrome/Puppeteer)
FLARESOLVERR_URL=http://127.0.0.1:8191/v1

# Cron / cache
SUMMARY_INTERVAL_MS=900000
CACHE_TTL_MS=900000
# 0 = sem cache no /api/service (sempre fresco). Use ?refresh=1 para forçar em qualquer endpoint.
SERVICE_CACHE_TTL_MS=0

# --- Cloudflare D1 (opcional) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=

# --- Power Automate / Teams (opcional) ---
POWER_AUTOMATE_WEBHOOK_URL=

# --- Cloudflare R2 (opcional) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
