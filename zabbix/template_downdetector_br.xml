    <templates>
        <template>
            <uuid>e35b82b1b5734265a619fd9eb64e650f</uuid>
            <template>Downdetector BR</template>
            <name>Downdetector BR</name>
            <description>Um host Zabbix = um serviço (WhatsApp, Instagram, …).&#10;&#10;No host, defina a macro:&#10;  {$DOWNDETECTOR.SLUG} = whatsapp&#10;&#10;Interface Agent = IP do servidor coletor (agent + FlareSolverr).&#10;&#10;Códigos: 1=ok, 2=warning, 3=danger, 0=unknown.</description>
            <groups>
                <group>
                    <name>Templates/Applications</name>
                </group>
            </groups>
            <items>
                <item>
                    <uuid>a18a8a5c88744bf1a5bfea272496eeac</uuid>
                    <name>Downdetector: raw</name>
                    <type>ZABBIX_PASSIVE</type>
                    <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    <delay>15m</delay>
                    <history>7d</history>
                    <trends>0</trends>
                    <value_type>TEXT</value_type>
                    <description>JSON completo do serviço.</description>
                    <tags>
                        <tag>
                            <tag>Application</tag>
                            <value>Downdetector</value>
                        </tag>
                    </tags>
                </item>
                <item>
                    <uuid>588d15e67e5f43e9b7cce1e22225308c</uuid>
                    <name>Downdetector: status code</name>
                    <type>DEPENDENT</type>
                    <key>downdetector.status.code</key>
                    <delay>0</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>UINT</value_type>
                    <description>1=ok 2=warning 3=danger 0=unknown</description>
                    <preprocessing>
                        <step>
                            <type>JSONPATH</type>
                            <parameters>
                                <parameter>$.status_code</parameter>
                            </parameters>
                            <error_handler>DISCARD_VALUE</error_handler>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    </master_item>
                    <tags>
                        <tag>
                            <tag>Application</tag>
                            <value>Downdetector</value>
                        </tag>
                    </tags>
                    <triggers>
                        <trigger>
                            <uuid>aa621e165ca74fc3885e94039b957bba</uuid>
                            <expression>last(/Downdetector BR/downdetector.status.code)=3</expression>
                            <name>Downdetector: {HOST.NAME} reporta problemas</name>
                            <priority>HIGH</priority>
                        </trigger>
                        <trigger>
                            <uuid>8e5bb217eab344b5be9710ec3e6c97cb</uuid>
                            <expression>last(/Downdetector BR/downdetector.status.code)=2</expression>
                            <name>Downdetector: {HOST.NAME} reporta possíveis problemas</name>
                            <priority>WARNING</priority>
                        </trigger>
                    </triggers>
                </item>
