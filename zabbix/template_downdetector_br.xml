<?xml version="1.0" encoding="UTF-8"?>
<zabbix_export>
    <version>5.0</version>
    <groups>
        <group>
            <name>Templates/Applications</name>
        </group>
    </groups>
    <templates>
        <template>
            <template>Downdetector BR</template>
            <name>Downdetector BR</name>
            <description>Um host Zabbix = um serviço (WhatsApp, Instagram, …).

No host, defina a macro:
  {$DOWNDETECTOR.SLUG} = whatsapp

Interface Agent = IP do servidor coletor (agent + FlareSolverr).

Códigos: 1=ok, 2=warning, 3=danger, 0=unknown.</description>
            <groups>
                <group>
                    <name>Templates/Applications</name>
                </group>
            </groups>
            <applications>
                <application>
                    <name>Downdetector</name>
                </application>
            </applications>
            <items>
                <item>
                    <name>Downdetector: raw</name>
                    <type>0</type>
                    <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    <delay>15m</delay>
                    <history>7d</history>
                    <trends>0</trends>
                    <status>0</status>
                    <value_type>4</value_type>
                    <description>JSON completo do serviço.</description>
                    <applications>
                        <application>
                            <name>Downdetector</name>
                        </application>
                    </applications>
                </item>
                <item>
                    <name>Downdetector: status code</name>
                    <type>18</type>
                    <key>downdetector.status.code</key>
                    <delay>0</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <status>0</status>
                    <value_type>3</value_type>
                    <description>1=ok 2=warning 3=danger 0=unknown</description>
                    <applications>
                        <application>
                            <name>Downdetector</name>
                        </application>
                    </applications>
                    <preprocessing>
                        <step>
                            <type>12</type>
                            <params>$.status_code</params>
                            <error_handler>1</error_handler>
                            <error_handler_params/>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    </master_item>
                </item>
                <item>
                    <name>Downdetector: status</name>
                    <type>18</type>
                    <key>downdetector.status.text</key>
                    <delay>0</delay>
                    <history>90d</history>
                    <trends>0</trends>
                    <status>0</status>
                    <value_type>1</value_type>
                    <applications>
                        <application>
                            <name>Downdetector</name>
                        </application>
                    </applications>
                    <preprocessing>
                        <step>
                            <type>12</type>
                            <params>$.status</params>
                            <error_handler>1</error_handler>
                            <error_handler_params/>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    </master_item>
                </item>
                <item>
                    <name>Downdetector: relatos</name>
                    <type>18</type>
                    <key>downdetector.reports</key>
                    <delay>0</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <status>0</status>
                    <value_type>3</value_type>
                    <applications>
                        <application>
                            <name>Downdetector</name>
                        </application>
                    </applications>
                    <preprocessing>
                        <step>
                            <type>12</type>
                            <params>$.reports</params>
                            <error_handler>1</error_handler>
                            <error_handler_params/>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    </master_item>
                </item>
                <item>
                    <name>Downdetector: baseline</name>
                    <type>18</type>
                    <key>downdetector.reports.baseline</key>
                    <delay>0</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <status>0</status>
                    <value_type>3</value_type>
                    <applications>
                        <application>
                            <name>Downdetector</name>
                        </application>
                    </applications>
                    <preprocessing>
                        <step>
                            <type>12</type>
                            <params>$.reports_baseline</params>
                            <error_handler>1</error_handler>
                            <error_handler_params/>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    </master_item>
                </item>
                <item>
                    <name>Downdetector: nome</name>
                    <type>18</type>
                    <key>downdetector.name</key>
                    <delay>0</delay>
                    <history>7d</history>
                    <trends>0</trends>
                    <status>0</status>
                    <value_type>1</value_type>
                    <applications>
                        <application>
                            <name>Downdetector</name>
                        </application>
                    </applications>
                    <preprocessing>
                        <step>
                            <type>12</type>
                            <params>$.name</params>
                            <error_handler>1</error_handler>
                            <error_handler_params/>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    </master_item>
                </item>
                <item>
                    <name>Downdetector: logo</name>
                    <type>18</type>
                    <key>downdetector.logo</key>
                    <delay>0</delay>
                    <history>7d</history>
                    <trends>0</trends>
                    <status>0</status>
                    <value_type>4</value_type>
                    <applications>
                        <application>
                            <name>Downdetector</name>
                        </application>
                    </applications>
                    <preprocessing>
                        <step>
                            <type>12</type>
                            <params>$.logo</params>
                            <error_handler>1</error_handler>
                            <error_handler_params/>
                        </step>
                    </preprocessing>
                    <master_item>
                        <key>downdetector.status[{$DOWNDETECTOR.SLUG}]</key>
                    </master_item>
                </item>
            </items>
            <macros>
                <macro>
                    <macro>{$DOWNDETECTOR.SLUG}</macro>
                    <value>whatsapp</value>
                    <description>Slug do serviço no Downdetector (ex.: whatsapp, instagram).</description>
                </macro>
            </macros>
        </template>
    </templates>
    <triggers>
        <trigger>
            <expression>{Downdetector BR:downdetector.status.code.last()}=3</expression>
            <name>Downdetector: {HOST.NAME} reporta problemas</name>
            <priority>4</priority>
            <status>0</status>
        </trigger>
        <trigger>
            <expression>{Downdetector BR:downdetector.status.code.last()}=2</expression>
            <name>Downdetector: {HOST.NAME} reporta possíveis problemas</name>
            <priority>2</priority>
            <status>0</status>
        </trigger>
    </triggers>
</zabbix_export>
