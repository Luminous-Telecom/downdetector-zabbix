# Token da API Zabbix — o timer usa isso para listar hosts do template.
#
# Users → API tokens → Create
# cp zabbix/downdetector-api.env.example /etc/zabbix/downdetector-api.env
# chmod 640 /etc/zabbix/downdetector-api.env && chown root:zabbix /etc/zabbix/downdetector-api.env

ZABBIX_URL=http://127.0.0.1/api_jsonrpc.php
ZABBIX_TOKEN=cole_aqui_o_token_gerado_no_zabbix
ZABBIX_TEMPLATE=downdetector

# Se a UI estiver em /zabbix/:
# ZABBIX_URL=http://127.0.0.1/zabbix/api_jsonrpc.php
