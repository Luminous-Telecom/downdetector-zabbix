# Credenciais da API Zabbix 7 — usado pelo timer downdetector-refresh
# (descobre os hosts com o template "downdetector"; Host name = slug).
#
# 1) No Zabbix web: Users → API tokens → Create (user Admin ou com leitura de hosts)
# 2) Copie este arquivo:
#      cp zabbix/downdetector-api.env.example /etc/zabbix/downdetector-api.env
#      chmod 640 /etc/zabbix/downdetector-api.env
#      chown root:zabbix /etc/zabbix/downdetector-api.env
# 3) Ajuste URL e token abaixo.

ZABBIX_URL=http://127.0.0.1/api_jsonrpc.php
ZABBIX_TOKEN=COLE_O_TOKEN_AQUI
ZABBIX_TEMPLATE=downdetector

# Se a instalação usar path /zabbix/:
# ZABBIX_URL=http://127.0.0.1/zabbix/api_jsonrpc.php
