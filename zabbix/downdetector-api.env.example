# 1) No Zabbix web: Users → API tokens → Create
#    (usuário Admin ou com permissão de leitura em hosts/templates)
# 2) Copie e ajuste:
#      cp zabbix/downdetector-api.env.example /etc/zabbix/downdetector-api.env
#      chmod 640 /etc/zabbix/downdetector-api.env
#      chown root:zabbix /etc/zabbix/downdetector-api.env
#
# NÃO use aspas no token. NÃO deixe COLE_O_TOKEN_AQUI.

ZABBIX_URL=http://127.0.0.1/api_jsonrpc.php
ZABBIX_TOKEN=cole_aqui_o_token_gerado_no_zabbix
ZABBIX_TEMPLATE=downdetector

# Se a UI for em /zabbix/:
# ZABBIX_URL=http://127.0.0.1/zabbix/api_jsonrpc.php

# Teste manual:
#   set -a; source /etc/zabbix/downdetector-api.env; set +a
#   python3 /opt/downdetector-zabbix/downdetector_scraper.py --refresh-all --delay 0
